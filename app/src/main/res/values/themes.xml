<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FoodExpiryAPP" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4D644F</item>
        <item name="colorPrimaryVariant">#364C39</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#556157</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Corner16Top" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerFull" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ThemeOverlay.App.SearchBar" parent="">
        <item name="colorOnSurface">@color/search_bar_text_original</item>
        <item name="colorOnSurfaceVariant">@color/search_bar_icon_original</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:textColorHint">@color/search_bar_hint_original</item>
    </style>
</resources>
